rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Activity tracker: batched samples (one doc per 5-min tick). Backend writes; clients read last 7 days.
    match /activitySamples/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Which factions to sample. Only backend (Callable) writes; clients read to see list.
    match /trackedFactions/{factionId} {
      allow read: if true;
      allow write: if false;
    }
    // API keys per faction (one doc per faction, keys array). Backend only; never expose to client.
    match /trackedFactionKeys/{factionId} {
      allow read, write: if false;
    }
    match /activityRegistrationsByPlayer/{playerId} {
      allow read, write: if false;
    }
    // VIP: balances and transactions. Backend (Callables) only; client calls callables.
    match /vipBalances/{playerId} {
      allow read, write: if false;
    }
    match /vipTransactions/{transactionId} {
      allow read, write: if false;
    }
    match /vipTornEventClaims/{claimId} {
      allow read, write: if false;
    }
    match /vipIncomingXanaxLog/{eventId} {
      allow read, write: if false;
    }
    match /vipIncomingXanaxPoll/{docId} {
      allow read, write: if false;
    }
    // Chain watch schedule (one doc per faction). Callables only — no client reads/writes.
    match /factionChainWatch/{factionId} {
      allow read, write: if false;
    }
    // Alliance Dashboard: roster + vault. Clients read for live UI; all writes go through Cloud Functions (Torn-verified).
    match /alliances/{allianceId} {
      allow read: if true;
      allow write: if false;
      match /vaultItems/{itemId} {
        allow read: if true;
        allow write: if false;
      }
      match /factionTerritory/{factionId} {
        allow read: if true;
        allow write: if false;
      }
    }
    // Alliance ↔ faction index (callable-only writes; clients use allianceListMine).
    match /allianceFactionMemberships/{docId} {
      allow read, write: if false;
    }
  }
}
